<!--
root 元素
d - dialog元素 树节点元素
c - children元素
t - title元素 对话标题
s - select选项 对话选项
c-s - showCount选项 对话选项的数目，用于随机对话项
tr - tran选项 传送

m - mass权重,某个选项出现的几率

p - params 参数,这个按自己的兴趣定

var info:DialogExInfo = DialogExXmlInfo.getDialogInfoById(7);
var a:DialogAdapter = new DialogAdapter(10002,info);
a.show();
-->

<root>
	<!--多选实例 -->
	<d id="1" t="这是标题1">
		<c>
			<d id="3" t="这是标题2" s="这是选项1">
				<c>
					<d id="4" s="这是选项4传送" tr="NPC_10001">
					</d>
					<d id="7" s="这是选项5">
					</d>
				</c>
			</d>
			<d id="5" t="这是标题3" s="这是选项2">
				<c>
					<d id="6" s="这是选项3">
					</d>
					<d id="10" s="分支选项">
					</d>
				</c>
			</d>
		</c>
	</d>
	
	<d id="2" t="这是第二个标题">
		<c>
			<d s="这是第二个标题的选项">
			</d>
		</c>
	</d>
	<!--切换npc实例，对话由默认npc切换到10001 -->
	<d id="7" t="今天天气好晴朗呀！">
		<d id="8" npc="10001" t="是呀，出来打麻将吧！" s="晴朗你妹">
			<c>
				<d s="我也要参加。">
				</d>
				<d s="我才不要打麻将。">
				</d>
			</c>
		</d>
	</d>
	<!--随机对话项实例-->
	<d id="1001" t="开学总动员，我可是将祖传的上古宝图拿出来了，谁能帮我完成一件事，我就送他一张上古宝图！在正确地方使用上古宝图，能获得绝世宝藏呢！">
		<c s="1">
			<d m="1" s="我愿意帮忙！" t="三阶侠士可厉害了，我想要成为三阶侠士，可是还缺少伏魔点，小侠士你可以送我50点吗？">
				<c>
					<d id="1002" s="当然可以。" p="2007">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t="前天我去虎丘林挖宝，挖出了十几颗水龙珠，可是都被那虎奔抢走了，小侠士你可以帮我去教训他一次吗？">
				<c>
					<d id="1003" s="我这就去。" p="2008">
					</d>
		<!-- 			<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t="听说小侠士们都在玩龙虎斗，我也好想去玩，可是我每天要帮助艾尔大陆的人挖宝，小侠士你愿意帮我去赢一场龙虎斗吗？">
				<c>
					<d id="1004" s="走起，战个痛快！" p="2009">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t="药师爷爷 曾托我帮他采集一些长生果皮，可是我忙于挖宝。你愿意帮我去采集10个长生果皮，交给我吗？">
				<c>
					<d id="1005" s="我这就去。" p="2010">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
		</c>
	</d>
	
	<d id="2001" t="你是来给我送美食的吗？ 我可是有好奖品等着你。">
		<c>
			<d id="2002" s="我有月饼，跟你换。">
			</d>
			<d t="轻轻松松打几个副本就能获得制作月饼的材料了，找到药师爷爷学会制药后，打开副职就能制作美味月饼了。" s="怎样获得月饼？">
				<c>
					<d id="2003" s="好，等着我给你送月饼来吧~">
					</d>
				</c>
			</d>
		</c>
	</d>
	
	<d id="3001" t="看来嫦娥都告诉你了，俺老猪只是想找点漂亮姑娘来点乐趣，你小娃娃就一边呆着去！">
		<c>
			<d t="哼，小娃娃，就凭你就能战胜我？可笑！ " s="我要好好教训你！">
				<c>
					<d id="3002" s="别得意，看我的！">
					</d>
				</c>
			</d>
		</c>
	</d>
	
	<d id="4001" t="中秋节到了，想去一睹嫦娥美貌的人可真不少啊，那老夫今日日就格外开恩，送你一程。">
		<c>
			<d s="现在就进去。" tr="NPC_10001"><!--传送到广寒宫-->
			</d>
		</c>
	</d>
	
	<d id="5001" t="俺老猪在这里叫唤半天了，嫦娥妹子也不出来见一面，让老猪等的好着急。">
		<c>
			<d t="还不是那只玉兔害的，那兔子厉害着呢，又是嫦娥的心爱之物，拦在门口，不敢动它。 " s="那你怎么不进去找她。">
				<c>
					<d t="你这娃娃还能想出什么好招" s="这个我有办法。">
						<c>
							<d t="小娃娃聪明，不过那兔子机灵着呢，你可要多试几次。" s="我有玉兔变身符，变身后把它引开就可以了。">
								<c>
                  <d id="5002" s="使用玉兔变身符！"></d>
								</c>
							</d>
						</c>
					</d>
				</c>
			</d>
		</c>
	</d>
	
	<d id="6001" t="那死猪已经在外叫唤好久了，他这人啊，真要好好教训他，尽喜欢调戏漂亮姑娘，见一个爱一个，真是让不少姑娘都头疼。">
		<c>
			<d t="虽然他这人不怎么样，但还是有点本事的，很多小侠士都被他打的吓跑了。 " s="他竟然是这样的人，我去帮你教训他！">
				<c>
					<d t="先让我考验下你的实力，看看有没有机会战胜他。" s="这么厉害？那我怎么才能打赢他。">
						<c>
							<d id="6002" s="来吧！">
							</d>
						</c>
					</d>
				</c>
			</d>
		</c>
	</d>
	<!--仙兽宝图任务-->
	<d id="7001" t="中秋月圆，艾尔大陆仙气聚集，变坏仙兽纷纷现身。我踏遍艾尔大陆所有关卡，对变坏仙兽出现地点了如指掌哦！帮我完成心愿，我就送你一张仙兽宝图，百分百遇到变坏仙兽！">
		<c s="1">
			<d m="1" s="我愿意帮忙！" t="三阶侠士可厉害了，我想要成为三阶侠士，可是还缺少伏魔点，小侠士你可以送我50点吗？">
				<c>
					<d id="7002" s="当然可以。" p="2024">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t=
			"中秋佳节，看着小侠士们都在吃月饼，真羡慕！你可以送我2个兔子月饼吗？">
				<c>
					<d id="7003" s="可以呢！" p="2025">
					</d>
		<!-- 			<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t="我就早听说九天连环里有不少宝贝，可是没有水龙珠，我进不去，小侠士你愿意送我1颗水龙珠吗？">
				<c>
					<d id="7004" s="没问题！" p="2026">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
			<d m="1" s="我愿意帮忙！" t="中秋月圆，稀世珍宝纷纷现身艾尔大陆，我在虎丘林寻到不少宝物，可是都被那虎贲抢走了，你能帮我教训他吗？">
				<c>
					<d id="7005" s="我这就去。" p="2027">
					</d>
<!-- 					<d s="让我再考虑考虑。">
					</d> -->
				</c>
			</d>
		</c>
	</d>
	<d id="8001" t="艾尔大陆的各位导师也来凑热闹了，他们将与你同台竞技。打起十二分精神应战吧！（每场比赛报名费20万功夫豆，小侠士化身魔王，可以使用随机技能战胜两位导师，获得丰厚奖励呦！）">
		<c>
			<d id="8002" s="我会尽快熟悉比赛的。">
			</d>
		</c>
	</d>
	<d id="9001" t="两人组队的侠士可由队长来领取仙器并合力施法使无头骑士显形，大战无头骑士时更会有奇遇发生！更能赢得传说中珍藏大量仙兽材料的古天庭宝箱，以及大量装备材料、铁匠装备！">
		<c>
			<d id="9002" s="2人组队大战无头骑士">
			</d>
			<d id="9003" s="捉拿无头骑士活动说明" tr="PANEL_NoHeadFighterPanel">
			</d>
		</c>
	</d>
	<d id="10001" t="这么久了，居然还会有人来到这里。勇敢的侠士，敢于接受远古风龙的考验吗？进入风龙的领域需要消耗一个%ITEM%，无穷的宝藏在等着你！">
		<c>
			<d id="10002" s="远古风龙吗？我要挑战你！">
			</d>
		</c>
	</d>
	<d id="11001" t="咦？你这小家伙居然不怕电？想去雷龙的领域试试吗？不过需要消耗一个%ITEM%才能进入！">
		<c>
			<d id="11002" s="远古雷龙？更让我期待了！">
			</d>
		</c>
	</d>
	<d id="12001" t="没想到你居然能过掉远古冰龙那一关,那战龙领域更适合你了！消耗一个%ITEM%，赶紧来挑战吧！">
		<c>
			<d id="12002" s="远古战龙！越来越让我兴奋了！">
			</d>
		</c>
	</d>
	<d id="13001" t="远古影龙，普通人根本无法看见他，只能依靠仙兽来判别方位，你能成功吗？进入影龙领域需要消耗一个%ITEM%！">
		<c>
			<d id="13002" s="让我来挑战影龙！">
			</d>
		</c>
	</d>
	<d id="14001" t="你终于进入了骨龙巢穴的深处并成功将我唤醒，最好的宝藏在等你！还不快来？进入骨龙巢穴需要消耗一个%ITEM%！">
		<c>
			<d id="14002" s="我来了！">
			</d>
		</c>
	</d>
	<d id="15001" t="万神殿将于3月7日的18:00-20:00,3月8日-3月9日的13:00-15:00开放，里面珍宝无数但也异常凶险，非安全区内可以相互pk并有几率掉落身上的天兵符和水晶宝石。">
		<c>
			<d id="15002" s="进入万神殿">
			</d>
			<d id="15003" s="天兵符抽奖">
			</d>
		</c>
	</d>
	<d id="16001" t="不好！黑衣人在抢功夫宝典！武圣爷爷有危险！">
		<c>
			<d id="16002" s="武圣爷爷，我来帮你！">
			</d>
		</c>
	</d>
</root>
