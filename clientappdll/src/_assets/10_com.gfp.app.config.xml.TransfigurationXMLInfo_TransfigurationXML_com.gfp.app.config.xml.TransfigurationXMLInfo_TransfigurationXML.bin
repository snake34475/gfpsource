<!-- 副职变身符相关配表 -->

<!-- PaperID 变身符ID -->
<!-- AppId 表现ID，与item_nor.xml里面ExID1字段对应 必填项 -->
<!-- SkillId 增加额外的技能ID ，战斗skill.xml需要提供相应实现 选填项 默认为0 -->
<!-- AddHp 增加额外的血量 ，默认为0 -->
<!-- AddMp 增加额外的蓝量 ，默认为0 -->
<!-- AddAtk 增加额外的攻击 ，默认为0 -->
<!-- ResID 变成为其它角色的ID ，默认为0 -->

<!-- InItem：需要消耗的物品 OutItem：产出的物品 均只支持物品，不支持装备和各种点数-->
<!-- UseUniversal：为1表示该消耗的物品能被万能碎片代替，默认为0 -->

<ChangeShape>

