<!--src="PANEL_TaskBookPanel,0"表明打开任务面板的第一页，即主线任务-->
	
<root>
	<node lv="5" npcID="10001" roleType="1|2|3|4" msg="勇敢的小侠士，虽经过诸多磨难，但你的努力已经成功激活了伏魔录！现在就点击右上方的伏魔录，接受新的挑战吧。再者，左护法瑶瑶也正在武圣大殿等着你哦。"/>
	<node lv="10" npcID="10025" roleType="0" msg="恭喜小侠士升到10级啦！每周五18:00和19:00，可以去一气学院兰娅处参加智力大比拼，获得丰厚经验，还有机会获得仙兽菊石；可以去功夫城北区参加新手武斗，享受pk的乐趣。"/>
	<node lv="25" npcID="10066" roleType="0" msg="恭喜小侠士升到25级啦，你即将接触智能副本，遇到更加强大的黑暗军团，加油！愿勇气与你同在。"/>
	<node lv="30" npcID="10005" roleType="0" msg="恭喜小侠士升到30级啦！可以去找右奇进行高级试炼，10重难度等你挑战！到达30级每天可以获得一次免费挖宝机会，快去功夫城西区找乌孙了解详情吧！"/>
	<node lv="35" npcID="10001" roleType="0" msg="勇敢的小侠士，相信你肯定希望得到更好的装备！完成真假武圣，通关伏魔塔，每周排行前十将获得橙装奖励！快打开伏魔录，去挑战吧。"/>
	<node lv="40" npcID="10072" roleType="0" msg="喜爱战斗的小侠士，勇气武斗场为你开放了哦。这里有更厉害的对手，更高的荣誉，当然还有更丰厚的奖励。快去功夫城北区找勇气武斗场管理员——白徵报名吧。"/>
	<node lv="45" npcID="10401" roleType="0" msg="孤身战斗的小侠士，想要和好兄弟并肩作战吗？精英武斗场开启了哦。这里进行多人对多人的战斗，每次获得精英积分将被记录。快去功夫城北区找精英武斗场管理员——剑叔报名吧。"/>
	<node lv="50" npcID="10001" roleType="0" msg="想要体验更厉害的boss吗？想要获得虚空套橙装吗？到达50级，虚空关卡为你开放。快打开伏魔录看看吧！"/>
	<!--<node lv="60" npcID="10430" roleType="0" msg="转眼小侠士都60级啦，更激情的黑暗武斗场为你们开放，这里有1v1和2v2的战斗，击败对手可获得丰厚功夫豆，还能拾取对方掉落道具！快去先锋哨岗找黑暗哨兵，进入黑暗武斗场吧！"/>-->	
	
