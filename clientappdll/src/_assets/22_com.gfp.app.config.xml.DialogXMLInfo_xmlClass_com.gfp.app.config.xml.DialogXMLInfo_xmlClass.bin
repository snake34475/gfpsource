		<taskOver/>
	</npc>
	<npc id="10150" name="大会主持人" resort="1">
		<first>
			<node><![CDATA[天下第一比武大会已经开赛啦，小侠士们加油！]]></node>
		</first>
		<custom>
			<pnode id="101516" prior="0" roleType="0"><![CDATA[保卫比武大会]]></pnode>
			<!--<pnode id="101515" prior="0" roleType="0"><![CDATA[武林风云影分身上周排行榜]]></pnode> -->
			<!--<pnode id="101514" prior="0" roleType="0"><![CDATA[武艺考验：龙虎斗获胜一场]]></pnode>-->
			<pnode id="101513" prior="0" roleType="0"><![CDATA[爱心考验:运送物资]]></pnode>
			<!--<pnode id="101510" prior="3" roleType="0"><![CDATA[龙虎斗]]></pnode>-->
			<pnode id="101505" roleType="0" prior="7"><![CDATA[查看比赛对阵]]></pnode>
