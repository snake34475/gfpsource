		<first>
			<node><![CDATA[现在唯有与神龙一战！]]></node>
		</first>
	</npc>
	<npc id="10575" name="大地龙皇">
		<first>
			<node><![CDATA[现在唯有与神龙一战！]]></node>
		</first>
	</npc>
	<npc id="10576" name="六翼神龙">
		<first>
			<node><![CDATA[我要让你们付出代价！]]></node>
		</first>
	</npc>
	<npc id="10577" name="寒冰龙皇">
		<first>
			<node><![CDATA[一定要阻止他！]]></node>
		</first>
	</npc>
	<npc id="10578" name="寒冰龙皇">
		<first>
			<node><![CDATA[一定要阻止他！]]></node>
		</first>
	</npc>
	<npc id="10579" name="寒冰龙皇">
		<first>
			<node><![CDATA[一定要阻止他！]]></node>
		</first>
	</npc>
	<npc id="10580" name="烈焰龙皇">
		<first>
			<node><![CDATA[一定要阻止他！]]></node>
		</first>
		<taskProcess>
			<task id="7005" pro="0">
				<node id="0">
					<node><![CDATA[六翼神龙的力量太强大了，刚觉醒的我们现在根本无法跟它对抗]]></node>
					<pnode><![CDATA[那怎么办啊，难道我们只能眼睁睁得看着魔界达成他们的目的么]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[我们不会让魔界得逞的！但是我们需要时间恢复能力。趁现在，小侠士，赶紧去拯救那些被困住的居民！]]></node>
					<pnode><![CDATA[遵命!龙皇！  ]]></pnode>
				</node>
			</task>
			<task id="7006" pro="0">
				<node id="0">
					<node><![CDATA[小侠士，完成的怎样了]]></node>
					<pnode><![CDATA[龙皇我顺利完成任务了。但是，龙皇，怎么才能使你们恢复力量呢？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[还记得使我们觉醒的神龙逆鳞么？我们靠它觉醒，也需要靠它恢复力量。]]></node>
					<pnode><![CDATA[但是现在神龙圣殿已经被六翼神龙占领了，我该从哪去获得呢？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[当初我还没觉醒的时候我就发现有个人在神龙圣殿附近鬼鬼祟祟的，现在意识到，原来那个人当时在打着神龙逆鳞的主意。]]></node>
					<pnode><![CDATA[原来还有这种人，我一定要将神龙逆鳞夺回来！]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[啊！那个人就在那！小侠士快去吧！]]></node>
					<pnode><![CDATA[小偷 往哪跑！]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
	<npc id="10581" name="六翼神龙">
		<first>
			<node><![CDATA[休想阻止我！]]></node>
		</first>
	</npc>
	<npc id="10582" name="六翼神龙">
		<first>
			<node><![CDATA[烈焰、寒冰、大地，你们的遗愿我将替你们完成！]]></node>
		</first>
	</npc>
	<npc id="10585" name="黑市商人">
		<first>
			<node><![CDATA[快来看看我这的好东西吧~~]]></node>
