	<npc id="10603" name="小青龙">
		<first>
			<node><![CDATA[我可是龙脉山山大王]]></node>
		</first>
		<taskProcess>
			<task id="7010" pro="0">
				<node id="0">
					<node><![CDATA[武圣爷爷，今日找你们有要事相商]]></node>
					<pnode><![CDATA[是，我们马上就去！]]></pnode>
				</node>
			</task>
			<task id="7011" pro="0">
				<node id="0">
					<node><![CDATA[想知道我是谁？我可是龙脉山山大王！]]></node>
					<pnode><![CDATA[额…居然遇到了“土匪“]]></pnode>
				</node>
			</task>
			<task id="7012" pro="0">
				<node id="0">
					<node><![CDATA[不要理我]]></node>
					<pnode><![CDATA[小青龙这是怎么了]]></pnode>
				</node>
			</task>
			<task id="7013" pro="0">
				<node id="0">
					<node><![CDATA[我一定要你们为所做的付出代价！]]></node>
					<pnode><![CDATA[小青龙是真的生气了]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
	<npc id="10604" name="小玄武">
		<first>
			<node><![CDATA[别看我个子小，大爷我可强着呢！]]></node>
		</first>
	</npc>
	<npc id="10605" name="小朱雀">
		<first>
			<node><![CDATA[什么时候能自由自在的飞行啊。]]></node>
		</first>
	</npc>
	<npc id="10606" name="小白虎">
		<first>
			<node><![CDATA[老爸就是我的目标。]]></node>
		</first>
	</npc>
	<npc id="10607" name="小守鹤">
		<first>
			<node><![CDATA[下次做个立体沙画看看！]]></node>
		</first>
	</npc>
	<npc id="10223" name="雪人王">
		<first>
			<node><![CDATA[小侠士们，捐献雪球活动已经圆满结束，上排行榜的小侠士可以领称号奖励啦~]]></node>
		</first>
		<app>
			<node src="IceManKingMainPanel" params="0" roleType="0"><![CDATA[雪人王的宝藏]]></node>
		</app>
	</npc>
	<npc id="10232" name="瑶瑶">
		<first>
			<node><![CDATA[我是左护法飞天猫瑶瑶，保护武圣爷爷和功夫宝典是我最大的责任！我擅长轻功，打探消息这种事就交给我吧！]]></node>
		</first>
		<taskProcess>
			<task id="2500" pro="0">
				<node id="0">
					<node><![CDATA[我一路追击乔伊的族人利牙，但被他逃走了。]]></node>
					<pnode><![CDATA[啊？连瑶瑶都会跟丢……]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[是的，他反侦察能力极强，发现了我。]]></node>
					<pnode><![CDATA[我看是他做贼心虚]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[我勉强追踪到这里，但无法再深入了。]]></node>
					<pnode><![CDATA[为什么，他躲起来了么？]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[靠近一下你就会明白了。]]></node>
					<pnode><![CDATA[这么神秘？我试试。]]></pnode>
				</node>
			</task>
			<task id="2500" pro="3">
				<node id="0">
					<node><![CDATA[小侠士领教了吧。]]></node>
					<pnode><![CDATA[这地方太可怕了。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[但这地方并不是完全无法进入。]]></node>
					<pnode><![CDATA[快说说有什么办法！]]></pnode>
				</node>
			</task>
			<task id="2500" pro="5">
				<node id="0">
					<node><![CDATA[守护神是探索这块区域的唯一希望了。]]></node>
					<pnode><![CDATA[原来是这样。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[我们已经在这里建立了一个据点。]]></node>
					<pnode><![CDATA[哦，是那个小屋么？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[没错，让我们来邀请一位守护神。]]></node>
					<pnode><![CDATA[好的，我试试。]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
	<npc id="10808" name="贪食之王">
		<first>
			<node><![CDATA[吾乃上古三魔兽之贪食之王饕餮，受死吧！]]></node>
		</first>
		<app>
			<node src="EatKingTaoTiePanel" roleType="0"><![CDATA[贪食之王饕餮]]></node>
		</app>
	</npc>
	<npc id="10809" name="恐惧之王">
		<first>
			<node><![CDATA[吾乃上古三魔兽之恐惧之王穷奇，受死吧！]]></node>
		</first>
		<app>
			<node src="KongBuKingQiongQiPanel" roleType="0"><![CDATA[恐惧之王穷奇]]></node>
