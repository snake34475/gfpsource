<!--
	======
	一级：
	<npc>对应一个npc所有对话功能
	二级：
	<first>Npc对话框开启的初始对话
	<normal>对话选项
	<taskAccept>可接受任务
	<taskProcess> 可进行的任务步骤
	<taskOver>可完成任务
	<options>多个选项对话
	三级：
	<node>npc说话内容
	<pnode>玩家选择项
	======
	
	添加表情：
	<embed name="e1" width="25" height="20" hspace="2" vspace="2"/>
	
	name 表情名 e0 ~ e23
	width 表情宽度
	height 表情高度
	hspace 水平两边的空隙
	vspace 垂直两边的空隙
	
	
	添加有色文字：
	<font color="#FF0000">xxxxxxxxx</font>
-->
<root>
	<npc id="10001" name="武圣爷爷">
		<first>
			<node><![CDATA[保护功夫宝典是每位弟子应尽的责任，我绝不会让利齿军团再次得逞！徒儿你也要努力啊，记得，勇气在你心中！]]></node>
		</first>
		<app>
			<node src="GreenDargonWishPanel" lv="80" roleType="0"><![CDATA[召唤青龙]]></node>
			<node src="GreenDargonRankPanel" lv="80" roleType="0"><![CDATA[召唤青龙排行榜]]></node>
			<node src="IdentifyStagePanel" lv="80" roleType="0"><![CDATA[真假武圣]]></node>
		</app>
		<custom>
			<pnode id="100013" roleType="0"><![CDATA[万神祝福（111级解锁）]]></pnode>
			<pnode id="100011" roleType="0"><![CDATA[挑战武圣]]></pnode>
			<pnode id="100012" roleType="0" lv="80"><![CDATA[魔界转生]]></pnode>
		</custom>
		<taskAccept>
			<task id="4">
				<node id="0">
					<node><![CDATA[让我来引荐一下右奇老师，他将负责你的强化训练。现在右奇一定在一气学院的中央操场上。]]></node>
					<pnode><![CDATA[我这就去找右奇老师。]]></pnode>
				</node>
			</task>
			<task id="32">
				<node id="0">
					<node><![CDATA[保护功夫宝典是每位弟子应尽的责任，我绝不会让利齿军团再次得逞！徒儿你也要努力啊，记得，勇气在你心中！]]></node>
					<pnode><![CDATA[加兰族的秘密]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[ 咳咳……泽之国，让你知道这个秘密的时刻要到了吗？如今在我们土地上的加兰族人，却遇到了前所未有的劫难。]]></node>
					<pnode><![CDATA[是谁蛊惑了加兰族人？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[我想，这事……和……他一定托不了干系。现在，最主要的是揭开铸剑谷中心的封印，那一定是加兰族人变残暴的起因！]]></node>
					<pnode><![CDATA[什么，他是谁？封印又是什么？]]></pnode>
				</node>
			</task>
			<task id="205">
				<node id="0">
					<node><![CDATA[难得你有这份心意，我的弟子派派他们已经前往矿山镇为我寻找药材，你可以去找矿山镇长老风行问问情况。]]></node>
					<pnode><![CDATA[我这就去，爷爷等我。]]></pnode>
				</node>
			</task>
			<task id="1192">
				<node id="0">
					<node><![CDATA[徒儿，我们大陆的东部有一座悬浮于大陆之外的宝塔。那是来自九霄的剑仙囚禁上古妖类的地方。可是最近，那里产生了一些异动。]]></node>
					<pnode><![CDATA[发生了什么事？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[利齿军团的首领乔伊妄想释放里面的妖类为自己所用。咳咳，剑侠们设下的结界可不是那么好破的为师年轻时也在剑仙门下学艺。这次的结界异动我也感受到了。]]></node>
					<pnode><![CDATA[啊，师傅，那里面的妖类怎么样了？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[虽说乔伊没有得逞，但是塔内的妖类们受到了他妖气的感染，想要冲出伏魔塔。现在，我需要勇敢的一气弟子，去制伏那些狂暴的上古妖类。]]></node>
					<pnode><![CDATA[师傅！派我去吧，我一定可以的！]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[塔内的妖类是这片大陆上妖怪的祖先，它们要凶残很多，你真的准备好了吗？]]></node>
					<pnode><![CDATA[是的，师傅！勇气在我心中！]]></pnode>
				</node>
				<node id="4">
					<node><![CDATA[那好，去找右奇老师吧，他会帮你前往悬浮的伏魔塔。]]></node>
					<pnode><![CDATA[好，我立刻就去！]]></pnode>
				</node>
			</task>
			<task id="54">
				<node id="0">
					<node><![CDATA[这颗石头上确实有敖清的气息，他的生命应该无恙，但是相当的虚弱。]]></node>
					<pnode><![CDATA[父亲还健在，太好了，我一定会把他救出来的。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[为什么这颗石头还在发着光呢？难道？小天快将宝典拿出来！]]></node>
					<pnode><![CDATA[好的，武圣爷爷。]]></pnode>
				</node>
			</task>
			<task id="55">
				<node id="0">
					<node><![CDATA[没有发现泰拉吗？嗯，让我们看看这个密令上写着什么吧。]]></node>
					<pnode><![CDATA[好的]]></pnode>
				</node>
			</task>
			<task id="1719">
				<node id="0">
					<node><![CDATA[刚才功夫城守卫来报好像在功夫城西发现了黑暗军团的踪迹，你去看看是怎么回事。]]></node>
					<pnode><![CDATA[好的，这就去]]></pnode>
				</node>
			</task>
			<task id="1721">
				<node id="0">
					<node><![CDATA[你做的非常好，根据密信上所写，几日后可能会有场大战，你去制作碧露丸和长生丸各5个给我，必要时这些药品会有大有用处。]]></node>
					<pnode><![CDATA[好的，这就去。]]></pnode>
				</node>
			</task>
			<task id="1722">
				<node id="0">
					<node><![CDATA[呵呵，你们来晚一步，那个昏迷的少女刚醒就十万火急地赶回中部大陆沙之洲了。只匆匆告诉我希望能够如信上所说得到我们的帮助，你们尽快准备行装前往沙之洲吧！此行非同小可，千万小心行事。]]></node>
					<pnode><![CDATA[好的，这就去。]]></pnode>
				</node>
			</task>
			<task id="1727">
				<node id="0">
					<node><![CDATA[接下来的测试可是有难度了哦，下一个你要通过药师爷爷的测试。不过透露个消息给你，药师爷爷一直惦记着伏魔塔右奇手上的玉珠祥灵草，但是右奇一直以来的规矩是只有有缘人通过四层伏魔塔的考验才能得到仙草，我相信你应该明白为师的意思了]]></node>
					<pnode><![CDATA[我这就去伏魔塔]]></pnode>
				</node>
			</task>
			<task id="1763">
				<node id="0">
					<node><![CDATA[我最近听闻有小侠士单枪匹马去找利爪军团挑战却惨遭失败啊。一个人的力量终有穷尽之时，只有齐心协力、互通长处的团队才能百战不殆。]]></node>
					<pnode><![CDATA[谨遵教诲]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[我已经命令刀郎准备了一种新型的训练，可以培养队员之间的协作能力。如果你愿意可以找刀郎接受考验。]]></node>
					<pnode><![CDATA[我这就去找他]]></pnode>
				</node>
			</task>
			<task id="1331">
				<node id="0">
					<node><![CDATA[最近功夫城来了些不速之客。我已经命石猛查明他们的真实身份。你去帮我询问一下他打探到了什么？]]></node>
					<pnode><![CDATA[我这就前去。]]></pnode>
				</node>
			</task>
			<task id="1333">
				<node id="0">
					<node><![CDATA[传闻修炼成变身之术，能召唤坐骑，纵横江湖，无往不利。伏魔塔有一朵七彩玲珑云，你可以前去捕获他，把他作为你的第一个坐骑。此云颇具灵性，可能较难捕捉，你要有点耐心。]]></node>
					<pnode><![CDATA[好的。]]></pnode>
				</node>
			</task>
			<task id="1773">
				<node id="0">
					<node><![CDATA[萝卜跟小桃每天细心地照料每一个小侠士的家园，你们的仙兽伙伴能够茁壮成长也少不了他们的功劳。]]></node>
					<pnode><![CDATA[他们俩真是太辛苦啦！]]></pnode>
				</node>
				<node id="0">
					<node><![CDATA[经过他们两人的努力，仙兽家园完全社区化啦，小侠士们现在可以在自己的家园中享受便利啦，请速速去感谢一下你们家园中辛勤的园丁吧]]></node>
					<pnode><![CDATA[好的，我这就去]]></pnode>
				</node>
			</task>
			<task id="2082">
				<node id="0">
					<node><![CDATA[你们是从哪里找到这个女孩的？]]></node>
					<pnode><![CDATA[将迷之少女的情况告诉武圣爷爷。]]></pnode>
				</node>
			</task>
		</taskAccept>
		<taskProcess>
			<task id="2082" pro="1">
				<node id="0">
					<node><![CDATA[药师爷爷那里或许会有治疗她的药丸。]]></node>
					<pnode><![CDATA[那现在就走吧！ ]]></pnode>
				</node>
			</task>
			<task id="519" pro="0">
				<node id="0">
					<node><![CDATA[咳…咳…咳…，尽管我用尽力气，还是被黑衣人抢走了半本宝典.身为宝典守护者，我真是无颜面对历代先辈啊！]]></node>
					<pnode><![CDATA[您先喝了药师爷爷调配的药吧。]]></pnode>
				</node>
			</task>
			<task id="2" pro="0">
				<node id="0">
					<node><![CDATA[咳…咳…咳…，尽管我用尽力气，还是被黑衣人抢走了半本宝典.身为宝典守护者，我真是无颜面对历代先辈啊！]]></node>
					<pnode><![CDATA[您先喝了药师爷爷调配的药吧。]]></pnode>
				</node>
			</task>
			<task id="2" pro="2">
				<node id="0">
					<node><![CDATA[咕咚……咕咚。不愧是药师师弟调制的灵药，我感觉好多了。]]></node>
					<node><![CDATA[众所周知，功夫宝典记录了功夫大陆所有的武功，这些禁忌的力量被封印在宝典里。]]></node>
					<node><![CDATA[如今宝典被撕裂，这些强大力量的也随之散落在大陆各个地方！]]></node>
					<pnode><![CDATA[那我们如何把禁忌的力量找回来呢？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[宝典守护者，只有宝典守护者才能召唤出宝典上的招式。才能拯救功夫大陆！]]></node>
					<pnode><![CDATA[谁是宝典守护者？]]></pnode>
				</node>
			</task>
			<task id="2" pro="4">
				<node id="0">
					<node><![CDATA[咳咳……天哪，你看，宝典与你产生共鸣了，你……你……就是被宝典选中的守护者！]]></node>
					<pnode><![CDATA[我？我成了宝典守护者？真的可以吗？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[正如你所看到的那样，宝典会选择自己的守护者，但他必定是坚强、勇敢、正义、聪明的小侠士。]]></node>
					<node><![CDATA[来吧，孩子，既然宝典选择了你，这片大陆的安宁与祥和就由你来守护了。]]></node>
					<node><![CDATA[不过……因为你被利齿军团所伤，原本的功力尽失，就连灵气铠甲也无法穿上了。]]></node>
					<pnode><![CDATA[什么？这不可能！]]></pnode>
				</node>
			</task>
			<task id="519" pro="2">
				<node id="0">
					<node><![CDATA[咕咚……咕咚。不愧是药师师弟调制的灵药，我感觉好多了。]]></node>
					<node><![CDATA[众所周知，功夫宝典记录了功夫大陆所有的武功，这些禁忌的力量被封印在宝典里。]]></node>
					<node><![CDATA[如今宝典被撕裂，这些强大力量的也随之散落在大陆各个地方！]]></node>
					<pnode><![CDATA[那我们如何把禁忌的力量找回来呢？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[宝典守护者，只有宝典守护者才能召唤出宝典上的招式。才能拯救功夫大陆！]]></node>
					<pnode><![CDATA[谁是宝典守护者？]]></pnode>
				</node>
			</task>
			<task id="519" pro="4">
				<node id="0">
					<node><![CDATA[咳咳……天哪，你看，宝典与你产生共鸣了，你……你……就是被宝典选中的守护者！]]></node>
					<pnode><![CDATA[我？我成了宝典守护者？真的可以吗？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[正如你所看到的那样，宝典会选择自己的守护者，但他必定是坚强、勇敢、正义、聪明的小侠士。]]></node>
					<node><![CDATA[来吧，孩子，既然宝典选择了你，这片大陆的安宁与祥和就由你来守护了。]]></node>
					<node><![CDATA[不过……因为你被利齿军团所伤，原本的功力尽失，就连灵气铠甲也无法穿上了。]]></node>
					<pnode><![CDATA[什么？这不可能！]]></pnode>
				</node>
			</task>
			<task id="412" pro="1">
				<node id="0">
					<node><![CDATA[为师看了你带来信，西部远征军的情况为师也了解了。没想到十二都天神魔阵在艾尔大陆重现，这无头骑士可真不简单！]]></node>
					<pnode><![CDATA[武圣爷爷知道他是谁吗？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[从信上对此人描述来看，为师怀疑他是曾经的西部王国的浩克将军。]]></node>
					<pnode><![CDATA[浩克将军？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[很久之前，为师去西部，见过他和乔伊一面。他们两一个沉着内敛，一个锋芒毕露，给我印象非常深刻。如果无头骑士真的是他，那就太遗憾了！]]></node>
					<pnode><![CDATA[为什么呢？]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[虽然只见过一面，但为师断定他是个忠肝义胆之人，至于为什么变成无头骑士，为师也很想知道。你可以前去西部大陆找理查德，打听关于浩克将军的事。]]></node>
					<pnode><![CDATA[我这就动身。]]></pnode>
				</node>
			</task>
			<task id="425" pro="2">
				<node id="0">
					<node><![CDATA[幽都东郊，那里以前可不是你现在看到的模样，也不叫幽都东郊。]]></node>
					<pnode><![CDATA[那叫什么？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[以前那里是西部王国王城东郊，是西部王国与黑暗军团大战的地方，埋藏了无数白骨啊！]]></node>
					<pnode><![CDATA[难怪那里阴森森的。]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[西部王国被黑暗军团打败后，王城沦为废墟。黑暗军团占领王城，听说将其改名幽都，王城东郊也变成了幽都东郊。]]></node>
					<pnode><![CDATA[等等！幽都？我们确实远远看到一处城墙，难道那里就是幽都？]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[据说幽都被黑暗军团用禁术封闭，没有人再进入过那里。可是我记得幽都和幽都东郊也消失了很久，怎么又出现了？]]></node>
					<pnode><![CDATA[是那个异象造成的。]]></pnode>
				</node>
				<node id="4">
					<node><![CDATA[嗯，看来西部大陆正发生着不为人知的事。徒儿，你可要小心查探。]]></node>
					<pnode><![CDATA[嗯，我一定小心。]]></pnode>
				</node>
			</task>
			<task id="302" pro="0">
				<node id="0">
					<node><![CDATA[天策吗？我猜你也该时候来了。]]></node>
					<pnode><![CDATA[这里是什么地方？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[这里是艾尔大陆东部的一气学院，你以后将在这里受到训练，逐渐变强。]]></node>
					<pnode><![CDATA[哼，我才不用训练呢。]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[在这里，你会遇到各路高手，而且随时会有各种为难发生，不可大意轻敌。]]></node>
					<pnode><![CDATA[敌人来一招我拆一招，不怕。]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[哈哈哈哈，果然年少轻狂，我现在就先不着急让你训练，你可以先熟悉下这周围的环境。]]></node>
					<pnode><![CDATA[那我自己先随便逛逛。]]></pnode>
				</node>
			</task>
			<task id="33" pro="5">
				<node id="0">
					<node><![CDATA[保护功夫宝典是每位弟子应尽的责任，我绝不会让利齿军团再次得逞！徒儿你也要努力啊，记得，勇气在你心中！]]></node>
					<pnode><![CDATA[师傅这是泽之使者让我带给你的泽之晶]]></pnode>
				</node>
			</task>
			<task id="34" pro="0">
				<node id="0">
					<node><![CDATA[等等，你手里捧着的滚烫的紫罗兰泽之晶，是泽之使者身体内的晶石吗？]]></node>
					<pnode><![CDATA[爷爷快快保存晶体，不能让泽之使者失去心智！]]></pnode>
				</node>
			</task>
			<task id="34" pro="2">
				<node id="0">
					<node><![CDATA[不好，如需揭开阵法，加上上次你带回来的5块晶体，还差1块重要的泽之晶！看来需要你速去取回这1颗晶体了！]]></node>
					<pnode><![CDATA[好的，我这就去！]]></pnode>
				</node>
			</task>
			<task id="38" pro="0">
				<node id="0">
					<node><![CDATA[我从乔伊的项链上发现了一些东西，这根项链有着记忆，通过我的大观镜，可以回到过去，或许可以发现事情的真相。]]></node>
					<pnode><![CDATA[回到过去？哇，听上去超酷的。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[慢着，大观镜很久没有使用了，上面占满了灰尘。你能去找找药师爷爷，看看他有什么办法吗？]]></node>
					<pnode><![CDATA[好的，我这就去问问药师爷爷。]]></pnode>
				</node>
			</task>
			<task id="39" pro="1">
				<node id="0">
					<node><![CDATA[哦，如此甚好。来，要小心，穿越，你会感到一点儿不适。]]></node>
					<pnode><![CDATA[没问题，我准备好了。]]></pnode>
				</node>
			</task>
			<task id="40" pro="5">
				<node id="0">
					<node><![CDATA[宝典终于复原了，乔伊的黑暗之魂被抽走了，现在的他，处于不生不死的状态。]]></node>
					<pnode><![CDATA[他还会醒过来吗？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[正如你知道的，乔伊原本是西部王国的大将军，可惜被魔化成了邪恶力量。我们好好照顾他的身体，希望有一天，他能清醒过来。]]></node>
					<pnode><![CDATA[恩。武圣爷爷，这本完整的功夫宝典，还是交还给你吧。]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[这其实是我们东部的青龙宝典，完整的宝典可以从我的体内召唤出我们东部大陆的守护使者青龙]]></node>
					<node><![CDATA[如果打败了青龙，那么，支撑我们东部大陆的光明支柱也会崩塌。到时候，整个东部大陆就会陷入黑暗的世界了。]]></node>
					<pnode><![CDATA[那其它的国家呢？他们会不会有危险？]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[我们的艾尔世界是一块浮于地面上方的浮空岛，分别由东南西北中，五块大陆组成。地面世界是黑暗的势力，现在，他们想占领我们的艾尔世界！种种迹象表明，西部王国已经被黑暗势力所占领。]]></node>
					<pnode><![CDATA[怎么办？我们不能让艾尔大陆被黑暗占领！]]></pnode>
				</node>
				<node id="4">
					<node><![CDATA[那些妖物很可能前往了南部大陆，他们的下一个目标是泽之国的光明支柱！你们现在已经有了足够的能力，前往更凶险的泽之国。]]></node>
					<pnode><![CDATA[好，我们这就前往泽之国！]]></pnode>
				</node>
				<node id="5">
					<node><![CDATA[这本完整的青龙宝典赠予名副其实的你——勇敢的宝典守护者！还有这枚青龙守护的戒指，拿着它，你有资格得到。]]></node>
					<pnode><![CDATA[谢谢武圣爷爷，我一定不辱使命。]]></pnode>
				</node>
			</task>
			<task id="52" pro="0">
				<node id="0">
					<node><![CDATA[好的，小天注意看好了]]></node>
					<pnode><![CDATA[武圣爷爷，这关系到我身世的水晶，我无法激活它]]></pnode>
				</node>
			</task>
			<task id="52" pro="2">
				<node id="0">
					<node><![CDATA[看来这就是事情的大致经过了。]]></node>
					<pnode><![CDATA[父亲。。武圣爷爷，我还发现一份密函]]></pnode>
				</node>
			</task>
			<task id="52" pro="4">
				<node id="0">
					<node><![CDATA[看来他们还是会再来的，小天你要刻苦修炼啊！]]></node>
					<pnode><![CDATA[是的，武圣爷爷。父亲。。。师父。。。我一定会回来救你们的。]]></pnode>
				</node>
			</task>
			<task id="53" pro="0">
				<node id="0">
					<node><![CDATA[小天，我感应到虎庙密道的妖气中居然有着，南部大陆守护使的气息，你前往虎庙密道查看一下吧。]]></node>
					<pnode><![CDATA[好的，我这就去看看。]]></pnode>
				</node>
			</task>
			<task id="54" pro="1">
				<node id="0">
					<node><![CDATA[果然，这个宝典就是打开玄武封印的钥匙之一，怪不得那个黑衣人会要抢回宝典。]]></node>
					<pnode><![CDATA[武圣爷爷，放心，我一定会保护好宝典的。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[既然宝典跟着你，说明你就是宝典守护者了，吸收了这颗玄武石，你的力量也会大增，我想那个泰拉应该还在虎庙，小天前往虎庙追击泰拉吧。]]></node>
					<pnode><![CDATA[武圣爷爷，我这就去。]]></pnode>
				</node>
			</task>
			<task id="55" pro="1">
				<node id="0">
					<node><![CDATA[这个巫罗看来是不简单，小天要小心呢。]]></node>
					<pnode><![CDATA[是的，武圣爷爷。父亲。。。师父。。。我一定会回来救你们的。]]></pnode>
				</node>
			</task>
			<task id="65" pro="0">
				<node id="0">
					<node><![CDATA[敖天，你已经知道了你自己的身份。]]></node>
					<pnode><![CDATA[是的，武圣爷爷！我要救出苏毕老师，打败居心不轨的叔叔！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[不仅仅如此，敖天。黑暗势力的入侵非常严重，恐怕整个泽之国已经在黑暗势力的掌控之下了。]]></node>
					<pnode><![CDATA[黑暗势力？他们要打碎我们泽之国的光之柱吗？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[黑暗势力还没有打开光之柱。孩子，好好保存你身上的玄武宝典，它不仅仅能给你带来功力上的提升。]]></node>
					<node><![CDATA[现在，你可以前往泽之国，跟你的师兄们汇合了！去吧，前往你的国家，拯救你的人民吧！]]></node>
					<pnode><![CDATA[是！武圣爷爷！]]></pnode>
				</node>
			</task>
			<task id="404" pro="0">
				<node id="0">
					<node><![CDATA[一封无字信？拿给我看看。用火烤烤看，果然，这是一封用牛奶写的信，风干后就看不见了，牛奶一遇热就能显现了。]]></node>
					<pnode><![CDATA[……好深奥，信上写了什么？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[信上说西部大陆黑暗军团正在秘密制造和运送火药炮弹，想一举击毁临界的北部大陆！]]></node>
					<pnode><![CDATA[什么！]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[大事不好！信上说负责运送火药炮弹的是一个叫深渊领主的家伙。]]></node>
					<pnode><![CDATA[我认识他，和他交过手！]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[嗯，你再去会会他和他的手下，记得把火药炮弹抢回来。]]></node>
					<pnode><![CDATA[我这就去！]]></pnode>
				</node>
			</task>
			<task id="420" pro="2">
				<node id="0">
					<node><![CDATA[徒儿，西部远征军情况怎么样？为师最近研究十二都天魔阵，已略有收获。]]></node>
					<pnode><![CDATA[哇，师傅真厉害。孙镰大将军让我告诉您，他需要更多援助。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[看来远征军形势不容乐观，黑暗军团采取行动，我们也不能坐以待毙。容为师思量一番，你且去休息。]]></node>
					<pnode><![CDATA[嗯，武圣爷爷再见。]]></pnode>
				</node>
			</task>
			<task id="2151" pro="0">
				<node id="0">
					<node><![CDATA[这次的仙魔争霸让我想起了二百年前的一个约定。]]></node>
					<pnode><![CDATA[二百年！爷爷，你的记忆力这么好你妈妈知道吗……]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[那是第一次魔界攻入艾尔大陆，我与魔灵族颂唱师魔铃的约定。]]></node>
					<pnode><![CDATA[魔铃？就是现在的迷之少女吗？可她一直不承认啊……]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[毕竟二百年过去了，我也不是很确定，可她又实在有太多相似了……]]></node>
					<pnode><![CDATA[现在已经有很多小侠士被卷进仙魔争霸了。]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[现在魔界五老峰的道路已通，正是开启约定的时候，来不及解释了，我们快走！]]></node>
					<pnode><![CDATA[到底是神马约定也不说明白……爷爷，别那么急，等等我~~]]></pnode>
				</node>
			</task>
			<task id="1464" pro="0">
				<node id="0">
					<node><![CDATA[这位少侠为何风尘仆仆？有什么事儿吗？]]></node>
					<pnode><![CDATA[武圣爷爷，我是敖天，我师父苏毕让我来找您。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[咦，这块玉佩，这是我的老伙计的东西啊。南部大陆的动荡真是令人不安啊。]]></node>
					<pnode><![CDATA[爷爷，这到底是怎么回事？师父他——]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[玉佩告诉了我一切，孩子。现在，你需要变得更强，才能为你师父报仇。]]></node>
					<pnode><![CDATA[恩，我知道了！师父给了我一本书，让我刻苦修炼！]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[这是南部的玄武宝典啊，利用它和你的能力，你可以在我们的世界，找到许多充满能量的琥珀进行修炼。]]></node>
					<pnode><![CDATA[是，爷爷！那我该去哪儿找呢？]]></pnode>
				</node>
				<node id="4">
					<node><![CDATA[能量琥珀蕴含于整个空间，现在，你可以前往不远的矿山镇，去那里看看。希望能有所收获。]]></node>
					<pnode><![CDATA[好的，谢谢爷爷，我知道了。]]></pnode>
				</node>
			</task>
			<task id="1329" pro="2">
				<node id="0">
					<node><![CDATA[你来得正好，黑暗势力为了破坏这次比武大会，派出了不少人马。现在，荣誉的时刻到来了！为了保护比武大会，五大队伍都会全力以赴。你准备好了吗？]]></node>
					<pnode><![CDATA[我准备好了！武圣爷爷。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[黑暗势力在关卡处设置了结界，每次进入关卡，都需要一个武灵珠。1个武灵珠可由<font color="#E59110">20伏魔点</font>兑换而来。现在，前往【比武大会报名员】那里，开始清除黑暗势力吧！把黑暗势力的【千年精魄】，拿到我这儿来]]></node>
					<pnode><![CDATA[我这就前往比武大会报名员那儿！]]></pnode>
				</node>
			</task>
			<task id="1329" pro="4">
				<node id="0">
					<node><![CDATA[你已经带来了千年精魄，我也该告诉你白玉狐的秘密了。]]></node>
					<pnode><![CDATA[白玉狐的秘密？]]></pnode>
				</node>
			</task>
			<task id="1720" pro="0">
				<node id="0">
					<node><![CDATA[这个少女受到黑暗能量的冲击所以一直昏迷，你先去三个危险之地收集噩梦碎片，希望可以通过噩梦碎片的能量吸收她体内的黑暗能量，将她唤醒。]]></node>
					<pnode><![CDATA[好的。]]></pnode>
				</node>
			</task>
			<task id="6203" pro="0">
				<node id="0">
					<node><![CDATA[谢谢你来通知我参加烧烤派对！]]></node>
					<pnode><![CDATA[不客气]]></pnode>
				</node>
			</task>
			<task id="6213" pro="0">
				<node id="0">
					<node><![CDATA[谢谢你来通知我参加烧烤派对！]]></node>
					<pnode><![CDATA[不客气]]></pnode>
				</node>
			</task>
			<task id="6223" pro="0">
				<node id="0">
					<node><![CDATA[谢谢你来通知我参加烧烤派对！！]]></node>
					<pnode><![CDATA[不客气]]></pnode>
				</node>
			</task>
