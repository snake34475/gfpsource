	<npc id="10810" name="愤怒之王">
		<first>
			<node><![CDATA[吾乃上古三魔兽之愤怒之王傲狠，受死吧！]]></node>
		</first>
		<app>
			<node src="AngryKingMainPanel" roleType="0"><![CDATA[愤怒之王傲狠]]></node>
		</app>
	</npc>
	<npc id="10811" name="混沌魔王">
		<first>
			<node><![CDATA[上古三魔兽的实力不及我万分之一，让你们尝尝混沌之力！]]></node>
		</first>
		<app>
			<node src="CKMondorPanel" roleType="0"><![CDATA[混沌魔王]]></node>
		</app>
	</npc>
	<npc id="10812" name="弱亚">
		<first>
			<node><![CDATA[快叫我一声好哥哥！]]></node>
		</first>
	</npc>
	<npc id="10233" name="欧总">
		<first>
			<node><![CDATA[不要叫我猫女，叫我MR.O大人！]]></node>
		</first>
		<custom>
			<pnode id="102331" roleType="0"><![CDATA[挑战Mr.O的残影]]></pnode>
		</custom>
		<taskProcess>
			<task id="6431" pro="0">
				<node id="0">
					<node><![CDATA[黑暗力量肆虐不绝，吾等正义之士理应有所担当，然而你们的实力还很弱，有很大的提升空间，是否愿意在我的训练下提升自我？]]></node>
					<pnode><![CDATA[我愿意！！！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[功夫宝典是残缺的，有些武学你们学的还是不够完整，以至于没法发挥出其巨大的威力！魔界大陆的深处，有许多强力的怪物，他们拥有一种称之为灵玉的东西，能极大程度的提升自己，还能根据每个人体质的不同开发出新的潜能！]]></node>
					<pnode><![CDATA[我一定会找到他们的！]]></pnode>
				</node>
			</task>
			<task id="6431" pro="1">
				<node id="0">
					<node><![CDATA[小侠士，快收集50个灵玉吧！灵玉可以从魔界大陆副本任意难度BOSS掉落。]]></node>
					<pnode><![CDATA[好的！]]></pnode>
				</node>
			</task>
			<task id="6431" pro="2">
				<node id="0">
					<node><![CDATA[干得漂亮，这么稀有的材料都被你获得了！等下别忘了去技能面板学习强化技能和被动技能哦~]]></node>
					<pnode><![CDATA[好的！]]></pnode>
				</node>
			</task>
			<task id="6432" pro="0">
				<node id="0">
					<node><![CDATA[之前施展72变时的浮空是不是很厉害啊，往往能够更加强力对敌人进行攻击！]]></node>
					<pnode><![CDATA[是啊，是啊，我也好想学啊！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[我可以教给你们，只要你们接受我严苛的训练！]]></node>
					<pnode><![CDATA[那让我试试吧！]]></pnode>
				</node>
			</task>
			<task id="6432" pro="2">
				<node id="0">
					<node><![CDATA[虽然你的实力还远远不如我，但足以学习浮空技能，等下别忘了去技能面板学习哦~ ]]></node>
					<pnode><![CDATA[好！]]></pnode>
				</node>
			</task>
			<task id="6433" pro="0">
				<node id="0">
					<node><![CDATA[我还有很多压箱底的武学没有教你们呢！]]></node>
					<pnode><![CDATA[真的嘛？有多强？！]]></pnode>
				</node>
			</task>
			<task id="6433" pro="1">
				<node id="0">
					<node><![CDATA[ 每个可都是我之前为你们煞费苦心度身定制的啊~！想学可是代价不菲哦~！]]></node>
					<pnode><![CDATA[不论多少，我一定要学到手！]]></pnode>
				</node>
			</task>
			<task id="6433" pro="5">
				<node id="0">
					<node><![CDATA[强悍的必杀技能马上就可获得哦！~等下快前往技能面板学习！~ ]]></node>
					<pnode><![CDATA[好！]]></pnode>
				</node>
			</task>
			<task id="6471" pro="0">
				<node id="0">
					<node><![CDATA[弱亚要减肥了！T T，再不减我就要养不起他了。。]]></node>
					<pnode><![CDATA[怎么会，你不是最最最富（kou）裕（men）的O总嘛- -！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[人家这么小出来打拼容易嘛，哪有这么多钱，不管怎么样，弱亚加油啊。。。]]></node>
					<pnode><![CDATA[嗯嗯，一定的!]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
	<npc id="10608" name="青龙左护法">
		<first>
			<node><![CDATA[慷慨自古英魂色，甘洒热血写青春。]]></node>
		</first>
		<!--<tollgate>
			<pnode id="1259" roleType="0" difficulty="1"><![CDATA[挑战黑龙复制体]]></pnode>
			<pnode id="1261" roleType="0" difficulty="1"><![CDATA[挑战暗黑魔龙]]></pnode>
		</tollgate>-->
		<taskProcess>
			<task id="7047" pro="0">
				<node id="0">
					<node><![CDATA[吾乃青龙左护法，见到我还不速速行礼！]]></node>
					<pnode><![CDATA[至于你信不信，反正我是不信的]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[现在的青龙使是谁？他没有告诉过你们我的大名么？]]></node>
					<pnode><![CDATA[哼，看我不叫武圣爷爷来教训你！]]></pnode>
				</node>
			</task>
			<task id="7048" pro="0">
				<node id="0">
					<node><![CDATA[你们可打听清楚了？]]></node>
					<pnode><![CDATA[清楚了，清楚了，左护法大人在上，晚辈有礼了]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[好，现在有一项任务交给你们，<font color="#FF0000">前往魔渊前线击败黑龙复制体</font>]]></node>
					<pnode><![CDATA[黑龙复制体？难道暗黑军团又在酝酿什么巨大的阴谋？]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[没错，这就是我再度现世的原因，助清龙使一臂之力，再次粉碎暗黑军团的阴谋！]]></node>
					<pnode><![CDATA[慷慨自古英魂色，甘洒热血写青春！我们定竭尽全力！]]></pnode>
				</node>
			</task>
			<task id="7048" pro="2">
				<node id="0">
					<node><![CDATA[看着你们伤痕累累的样子，想必并没有击败黑龙复制体]]></node>
					<pnode><![CDATA[他的攻击力太强了，我们无法承受]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[这不怪你们，当年连青龙都无法承受住黑龙的攻击力，我们需要<font color="#FF0000">新的策略</font>]]></node>
					<pnode><![CDATA[新的策略？]]></pnode>
				</node>
			</task>
			<task id="7049" pro="0">
				<node id="0">
					<node><![CDATA[为了击败黑龙复制体，我们需要能够承受住他攻击帮手——<font color="#FF0000">英魂</font>]]></node>
					<pnode><![CDATA[<font color="#FF0000">英魂</font>？和我们的仙兽类似吗？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[同样是战斗时的得力助手，但仙兽主要承担<font color="#FF0000">强化输出</font>的任务，而英魂主要承担<font color="#FF0000">承受攻击</font>的任务]]></node>
					<pnode><![CDATA[哇塞！有了<font color="#FF0000">英魂</font>的帮助我们一定可以击败黑龙复制体！]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[没错，我将派出上古英魂——<font color="#FF0000">不败之魂</font>助我们一臂之力击溃黑龙复制体。去和它并肩作战击败敌人！]]></node>
					<pnode><![CDATA[好，我这就出发！]]></pnode>
				</node>
			</task>
			<task id="7049" pro="2">
				<node id="0">
					<node><![CDATA[看来黑龙复制体已经被你们击败，暗黑军团已暂时偃旗息鼓。]]></node>
					<pnode><![CDATA[是的多亏了<font color="#FF0000">不败之魂</font>的帮忙。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[为了表示感谢以后<font color="#FF0000">去领取你们的奖励吧</font>！]]></node>
					<pnode><![CDATA[真的！太感谢左护法了！]]></pnode>
				</node>
			</task>
			<!--<task id="2501" pro="0">
				<node id="0">
					<node><![CDATA[和平的日子总是显得格外短暂，这次暗黑军团派出了<font color="#FF0000">真正的黑龙前来进犯</font>]]></node>
					<pnode><![CDATA[只要有<font color="#FF0000">英魂</font>的帮助，拿下黑龙不在话下！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[可千万别小觑了可怕的对手，你们要时刻牢记：同样是战斗时的得力助手，仙兽主要承担<font color="#FF0000">强化输出</font>的任务，而英魂主要承担<font color="#FF0000">承受攻击</font>的任务]]></node>
					<pnode><![CDATA[我记住了！这次也一定能够站胜敌人！]]></pnode>
				</node>
			</task>
			<task id="2501" pro="2">
				<node id="0">
					<node><![CDATA[看来在你们的通力合作之下已经彻底将敌人击退。]]></node>
					<pnode><![CDATA[是的，<font color="#FF0000">英魂</font>替我承担了无数攻击，居功至伟！]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[为了感谢你们又一次击败了敌人<font color="#FF0000">不败之魂将在以后的日子了跟随你们南征北战保卫艾尔大陆的和平</font>]]></node>
					<pnode><![CDATA[太好了！有了<font color="#FF0000">不败之魂</font>的帮助，我们定能战胜所有敌人！]]></pnode>
				</node>
			</task>-->
			<task id="510" pro="0">
				<node id="0">
					<node><![CDATA[小侠士，你可知道刚你获得的不败之魂，有何用途。]]></node>
					<pnode><![CDATA[并不知道。]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[无知的少年啊，英魂可是由古代将士的魂魄幻化而成的，他能保护你，帮你抵挡大量伤害。]]></node>
					<pnode><![CDATA[哇，这么厉害啊，那我是不是可以不用怕别人了。]]></pnode>
				</node>
				<node id="2">
					<node><![CDATA[你可以在你需要的时候召唤英魂出来帮助你，但他的生命是有限的。]]></node>
					<pnode><![CDATA[我一定会好好让英魂发挥作用的。]]></pnode>
				</node>
				<node id="3">
					<node><![CDATA[来吧，先让你看下英魂的作用吧！]]></node>
					<pnode><![CDATA[来吧，我已经准备好了。]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
	<npc id="10234" name="刀郎分身">
		<first>
			<node><![CDATA[在这里你可以使用试炼崖掉落的材料兑换到各式各样的龙珠，祝你成功！]]></node>
		</first>
		<shop>
			<pnode id="10234" roleType="0"><![CDATA[龙珠兑换(商店)]]></pnode>
		</shop>
	</npc>
	<npc id="10235" name="小阴">
		<first>
			<node><![CDATA[小阳被坏人抓走了，你们一定要帮我找回它。]]></node>
		</first>
		<taskProcess>
			<task id="7053" pro="0">
				<node id="0">
					<node><![CDATA[啊啊啊啊，身体好难受……]]></node>
					<pnode><![CDATA[你怎么了？]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[我感觉我的身体快裂开了，你们快走开！不然就伤害到你们了。]]></node>
					<pnode><![CDATA[我有什么办法能帮你吗？]]></pnode>
				</node>
			</task>
			<task id="7054" pro="0">
				<node id="0">
					<node><![CDATA[我，我看见小阳了，可是他变的好奇怪。]]></node>
					<pnode><![CDATA[小阳肯定是遭人毒手了。]]></pnode>
				</node>
			</task>
			<task id="7055" pro="0">
				<node id="0">
					<node><![CDATA[我，我看见小阳了，可是他变的好奇怪。]]></node>
					<pnode><![CDATA[小阳肯定是遭人毒手了。]]></pnode>
				</node>
			</task>
			<task id="7056" pro="0">
				<node id="0">
					<node><![CDATA[你们想要这力量，我便把这力量还给四方天地乾坤。]]></node>
					<pnode><![CDATA[小阴不要，你释放这些力量的后果无法预知。]]></pnode>
				</node>
			</task>
			<task id="7057" pro="0">
				<node id="0">
					<node><![CDATA[我一定要弥补之前的愚蠢行为，带他们逃出生天。]]></node>
					<pnode><![CDATA[你终于恢复了，也不枉费小阴的一番苦心]]></pnode>
				</node>
			</task>
			<task id="7058" pro="0">
				<node id="0">
					<node><![CDATA[为什么特训吖，好想去玩]]></node>
					<pnode><![CDATA[快来吧小阴]]></pnode>
				</node>
			</task>
			<task id="7059" pro="0">
				<node id="0">
					<node><![CDATA[我们现在已经很厉害了呢]]></node>
					<pnode><![CDATA[………………]]></pnode>
				</node>
			</task>
			<task id="7060" pro="0">
				<node id="0">
					<node><![CDATA[天下大势，又一番腥风血雨要来了]]></node>
					<pnode><![CDATA[乱世出英雄，我就是那英雄]]></pnode>
				</node>
			</task>
			<task id="7061" pro="0">
				<node id="0">
					<node><![CDATA[领主，乃统领一方之主]]></node>
					<pnode><![CDATA[领主？嘿嘿，我也去争上一争]]></pnode>
				</node>
			</task>
			<task id="7062" pro="0">
				<node id="0">
					<node><![CDATA[以小侠士的性格，领主之争肯定会被他搅得一团糟]]></node>
					<pnode><![CDATA[嘿嘿，我也去争上一争，大闹一番]]></pnode>
				</node>
			</task>
			<task id="7063" pro="0">
				<node id="0">
					<node><![CDATA[五大流派是什么？]]></node>
					<pnode><![CDATA[听起来似乎很厉害。]]></pnode>
				</node>
			</task>
			<task id="7064" pro="0">
				<node id="0">
					<node><![CDATA[天下英雄为了龙虎榜上排名不惜兵刃相见!]]></node>
					<pnode><![CDATA[龙虎榜，将江湖上侠士的战力分了开来。]]></pnode>
				</node>
			</task>
			<task id="7065" pro="0">
				<node id="0">
					<node><![CDATA[战区第一奖励丰厚，看来这第一届是被桃花岛的人拿去了!]]></node>
					<pnode><![CDATA[哼，第一届已经打完，但还有第二届，等到那时我们来决一死战。]]></pnode>
				</node>
			</task>
			<task id="7066" pro="0">
				<node id="0">
					<node><![CDATA[大陆既已有第一荣耀之称，全武林也是时候决出一个绝代霸王了。]]></node>
					<pnode><![CDATA[我已经迫不及待了。]]></pnode>
				</node>
			</task>
			<task id="7067" pro="0">
				<node id="0">
					<node><![CDATA[这只小猫咪好漂亮呀。]]></node>
					<pnode><![CDATA[它可爱的外表下隐藏着强大的能量。]]></pnode>
				</node>
			</task>
			<task id="7068" pro="0">
				<node id="0">
					<node><![CDATA[又有一个东西从天上掉下来了耶。]]></node>
					<pnode><![CDATA[那个东西，好像是，雷族神灵。]]></pnode>
				</node>
			</task>
			<task id="7069" pro="0">
				<node id="0">
					<node><![CDATA[上古斗魂，是英魂中最强的一种，他们秉持不灭战意而生，为战而活。]]></node>
					<pnode><![CDATA[斗魂，即使是时间长河也无法磨灭他们战斗的欲望。]]></pnode>
				</node>
			</task>
			<task id="6472" pro="0">
				<node id="0">
					<node><![CDATA[听说弱亚哥哥要减肥啊！小阳是不是打西边出来了。。。]]></node>
					<pnode><![CDATA[他这次好像是认真的哦，都不鼓励他一下- - 、]]></pnode>
				</node>
				<node id="1">
					<node><![CDATA[好吧，我相信弱亚哥哥！你告诉他，如果他瘦下来我就嫁给他！【害羞】]]></node>
					<pnode><![CDATA[额。。。那小阳肿么办 - 、]]></pnode>
				</node>
			</task>
			<task id="7070" pro="0">
				<node id="0">
					<node><![CDATA[守护神，提供给我们各种各样的庇佑。]]></node>
					<pnode><![CDATA[但我从来没有见过他们自己出手。]]></pnode>
				</node>
			</task>
			<task id="7071" pro="0">
				<node id="0">
					<node><![CDATA[风系弱亚，却飘不起来。]]></node>
					<pnode><![CDATA[其实……胖子都是潜力股。]]></pnode>
				</node>
			</task>
			<task id="7072" pro="0">
				<node id="0">
					<node><![CDATA[听说海之神女要来？]]></node>
					<pnode><![CDATA[是的，我已经嗅到了大海的芬芳……]]></pnode>
				</node>
			</task>
			<task id="7073" pro="0">
				<node id="0">
					<node><![CDATA[艾尔有六杰，最小最萌的是坑利]]></node>
					<pnode><![CDATA[现在他变得很强大了]]></pnode>
				</node>
			</task>
			<task id="7074" pro="0">
				<node id="0">
					<node><![CDATA[小小玄武，没有烦恼]]></node>
					<pnode><![CDATA[神龟玄武，防御天下第一]]></pnode>
				</node>
			</task>
		</taskProcess>
	</npc>
