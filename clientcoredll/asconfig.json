{
	"config": "air",
	"compilerOptions": {
		"source-path": [
			"src"
		],
		"library-path": [
			"libs"
		],
		"output": "bin/clientcoredll.swf",
		"default-background-color": "#ffffff",
		"default-frame-rate": 24,
		"default-size": {
			"width": 500,
			"height": 500
		},
		"swf-version": 11
	},
	"application": "src/clientcoredll-app.xml",
	"mainClass": "ClientCoreDLL"
}